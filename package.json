{
  "name": "bebras-bolivia-gen",
  "version": "1.0.0",
  "description": "BebrasBolivia Gen - Collaborative Platform (Monorepo)",
  "private": true,
  "workspaces": [
    "servicios",
    "cliente"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "validate": "npm run format && npm run lint && npm test",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "install:all": "npm ci && npm --prefix servicios ci && npm --prefix servicios/servicio-usuario ci"
  },
  "engines": {
    "node": "22.22.2",
    "npm": "10.9.7"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "commitlint": "17.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prisma": "^6.18.0",
    "ts-jest": "^29.4.5",
    "typescript": "^6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
